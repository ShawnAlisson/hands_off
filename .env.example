# Copy to .env — then: npm run dev
# Never commit .env (gitignored). See DEMO.md for the full walkthrough.

# Manus AI — LLM for outreach, owner chat, and site copy
MANUS_API_KEY=

# Supabase — state persisted to Storage (bucket auto-creates)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Wassist — WhatsApp outreach (optional live phone)
WASSIST_API_KEY=
WASSIST_AGENT_ID=
WASSIST_DEMO_PHONE=
# Required for cold outreach if recipient never messaged you — template name from WhatsApp Business Manager
WASSIST_TEMPLATE_NAME=

# PayPal Sandbox — owner checkout on offer portal
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
NEXT_PUBLIC_PAYPAL_CLIENT_ID=
PAYPAL_MODE=sandbox

# App URL (for offer links in outreach)
NEXT_PUBLIC_APP_URL=http://localhost:3000
